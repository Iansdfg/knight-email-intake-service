# Replace these values with your AWS RDS PostgreSQL endpoint and credentials.
# Keep sslmode=require unless your RDS parameter group/security policy says otherwise.
DATABASE_URL=postgresql+psycopg://email_intake_user:CHANGE_ME@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/email_intake?sslmode=require

STORAGE_BACKEND=s3
ROOT_PATH=/prod
S3_BUCKET=email-intake-submissions
AWS_REGION=us-east-1
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/QUEUE_NAME
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_REPLY_FROM=submissions@example.com
SMTP_REPLY_ENABLED=false
DUPLICATE_WINDOW_MINUTES=60
LOG_LEVEL=INFO
